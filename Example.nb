             StyleBox["a", "TI"], 
             StyleBox["b", "TI"], 
             StyleBox["c", "TI"]}]], ")"}], "2"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\left(f^{a b c}\\right)^2", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "484fe764-e7e4-430e-a96b-a20f2b9f9610"],
 "), it was immediately simplified to the adjoint quadratic Casimir. That \
is:"
}], "Text",
