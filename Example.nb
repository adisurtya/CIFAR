Cell[TextData[{
 "Since the adjoint trace found here was minimal (i.e.  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        RowBox[{"(", 
