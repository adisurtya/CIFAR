    ColorFunction->RGBColor],
   BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
   Selectable->False],
  DefaultBaseStyle->"ImageGraphics",
  ImageSize->{452.33333333333275`, Automatic},
  ImageSizeRaw->{598., 176.},
  PlotRange->{{0, 598.}, {0, 176.}}]], "Text",
 CellChangeTimes->{{3.953148440454287*^9, 3.9531484425495777`*^9}, {
  3.953148685574746*^9, 
  3.95314868766918*^9}},ExpressionUUID->"ee9123f1-25c0-464b-b74c-\
7b005447c568"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["q", "TI"], 
         OverscriptBox[
          StyleBox["q", "TI"], "_"], "\[Rule]", "\[Gamma]", 
         StyleBox["g", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "q\\bar {q} \\rightarrow\\gamma g", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Plain",ExpressionUUID->
  "dac918bc-95e9-4b4e-bd76-d0ad9951c6ec"],
 " ",
 StyleBox["at Three Loops",
  FontWeight->"Bold"],
 "\nAll fermion lines are quarks, with fundamental color indices labeled ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["i", "TI"], ", ", 
         StyleBox["j", "TI"], ", ", 
         StyleBox["k", "TI"], ", ", 
         SubscriptBox[
          StyleBox["i", "TI"], "1"], ", ", 
         SubscriptBox[
          StyleBox["i", "TI"], "2"], ", ", 
         SubscriptBox[
          StyleBox["i", "TI"], "3"], ","}], TraditionalForm], "errors" -> {}, 
     "input" -> "i, \\, j, \\, k, \\, i_ 1, \\, i_ 2, \\, i_ 3, ", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a4a0daf2-f077-45be-8b40-e390f4814dc9"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["i", "TI"], "4"], TraditionalForm], "errors" -> {}, "input" -> 
     "i_ 4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "606771bc-2759-431a-b3cb-8bca9243a624"],
 " . Gluons have adjoint color indices labeled ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], "1"], ", ", 
         SubscriptBox[
          StyleBox["a", "TI"], "2"], ", ", 
         SubscriptBox[
          StyleBox["a", "TI"], "3"], ", ", 
         SubscriptBox[
          StyleBox["a", "TI"], "4"], ", ", 
         SubscriptBox[
          StyleBox["a", "TI"], "5"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "a_ 1, \\, a_ 2, \\, a_ 3, \\, a_ 4, \\, a_ 5", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d42a3d2-9711-487d-8fd0-945fc8ddae04"],
 ",  and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["a", "TI"], "6"], TraditionalForm], "errors" -> {}, "input" -> 
     "a_ 6", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "129377a6-8e73-439e-b320-14e30e2fbcd7"],
 ". We can project the color factor to a scalar quantity by contracting with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["t", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["k", "TI"]}], 
        SubscriptBox[
         StyleBox["a", "TI"], "1"]], TraditionalForm], "errors" -> {}, 
     "input" -> "t^{a_1}_{i k}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0a5970fd-594d-4339-b836-f0edf4263b5a"],
 ". From QCD Feynman rules, the color factor for this diagram after \
projecting is:\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["D", "TI"], "\[LongEqual]", 
         SubscriptBox["\[Delta]", 
          RowBox[{
            SubscriptBox[
             StyleBox["i", "TI"], "1"], 
            SubscriptBox[
             StyleBox["i", "TI"], "2"]}]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["i", "TI"], "2"], 
            SubscriptBox[
             StyleBox["i", "TI"], "3"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "1"]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["i", "TI"], "3"], 
            SubscriptBox[
             StyleBox["i", "TI"], "4"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "2"]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["i", "TI"], "4"], 
            SubscriptBox[
             StyleBox["i", "TI"], "1"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "3"]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "1"]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["j", "TI"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "5"]], 
         SubsuperscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["i", "TI"]}], 
          SubscriptBox[
           StyleBox["a", "TI"], "6"]], 
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "3"], 
            SubscriptBox[
             StyleBox["a", "TI"], "4"], 
            SubscriptBox[
             StyleBox["a", "TI"], "5"]}]], 
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "2"], 
            SubscriptBox[
             StyleBox["a", "TI"], "6"], 
            SubscriptBox[
             StyleBox["a", "TI"], "4"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "D=\\delta_{i_1 i_2} t^{a_1}_{i_2 i_3} t^{a_2}_{i_3 i_4}  t^{a_3}_{i_4 \
i_1} t^{a_1}_{i k}t^{a_5}_{k j}t^{a_6}_{j i} f^{a_3 a_4 a_5} f^{a_2 a_6 a_4}",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9e62b190-c0e9-4ed8-989d-e86d98538bd0"],
 ".\nWe express this in ",
 StyleBox["CIFAR",
  FontSlant->"Italic"],
 " as the product of various color objects:"
}], "Text",
 CellChangeTimes->{{3.953148732331419*^9, 3.953148803706026*^9}, {
  3.953149316672318*^9, 3.953149359185423*^9}, {3.953149441898522*^9, 
  3.953149495267425*^9}, {3.9531501848497143`*^9, 3.9531502079729156`*^9}, {
  3.953152057108127*^9, 
  3.953152101375161*^9}},ExpressionUUID->"4a9f8484-3fe7-4fb3-80ea-\
7bdb86a9836b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"expr", "=", 
   RowBox[{
    RowBox[{"deltaF", "[", 
     RowBox[{"i1", ",", "i2"}], "]"}], " ", 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a1", "}"}], ",", "i2", ",", "i3"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a2", "}"}], ",", "i3", ",", "i4"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a3", "}"}], ",", "i4", ",", "i1"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a1", "}"}], ",", "i", ",", "k"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a5", "}"}], ",", "k", ",", "j"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", "a6", "}"}], ",", "j", ",", "i"}], "]"}], 
    RowBox[{"ff", "[", 
     RowBox[{"a3", ",", "a4", ",", "a5"}], "]"}], 
    RowBox[{"ff", "[", 
     RowBox[{"a2", ",", "a6", ",", "a4"}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.953150209137762*^9, 3.953150243723371*^9}, 
   3.953150312574654*^9, {3.953150376924765*^9, 3.95315043531022*^9}, {
   3.953152121945655*^9, 3.953152123592524*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"21ffe268-9f3d-4c7f-a04f-05b9e777c5de"],

Cell[TextData[{
 StyleBox["ff", "Input"],
 "\[CloseCurlyQuote]s represent structure constants, ",
 StyleBox["TT", "Input"],
 "\[CloseCurlyQuote]s represent generators in the fundamental representation, \
and ",
 StyleBox["deltaF", "Input"],
 " is a Kronecker delta symbol in the fundamental representation."
}], "Text",
 CellChangeTimes->{{3.953151781177651*^9, 3.953151860937302*^9}, {
  3.9531521603901787`*^9, 3.95315219746741*^9}, {3.953381306384985*^9, 
  3.953381307531554*^9}},ExpressionUUID->"833c65d2-88ef-416c-9710-\
719eeaf1eb12"],

Cell[CellGroupData[{

Cell[TextData[{
 "Full Reduction using ",
 StyleBox["CIFARReduce", "Input"]
}], "Subsection",
 CellChangeTimes->{{3.953150450614582*^9, 3.953150453274495*^9}, {
  3.953150999815243*^9, 
  3.9531510048752747`*^9}},ExpressionUUID->"79936e26-276a-458d-ad25-\
96b4066cbe85"],

Cell["\<\
To fully reduce this expression in terms of Casimir invariants / dimensions \
of representations of the color algebra, we can use the all-in-one function:\
\>", "Text",
 CellChangeTimes->{{3.953150457638755*^9, 3.95315047274004*^9}, {
  3.953150537023712*^9, 
  3.953150568862536*^9}},ExpressionUUID->"03cc97b1-ca13-43d8-b6e4-\
b83321fd1b38"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"exprCIFAR", "=", 
  RowBox[{"CIFARReduce", "[", "expr", "]"}]}]], "Input",
 CellChangeTimes->{{3.953150571160634*^9, 3.9531505790586643`*^9}, {
  3.9669917809589977`*^9, 3.966991789810926*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"f5074022-c254-4263-af77-51688a100f7e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"C3FF", " ", "CA"}], "2"]}], "-", 
  RowBox[{
   FractionBox["1", "8"], " ", 
   SuperscriptBox["CA", "2"], " ", "DA", " ", 
   SuperscriptBox["TF", "2"]}]}]], "Output",
 CellChangeTimes->{
  3.953150579422783*^9, 3.9531521283377953`*^9, 3.9531598067957563`*^9, 
   3.9533140188362503`*^9, 3.953381242214281*^9, 3.954527214205985*^9, 
   3.9545272496906853`*^9, 3.9617787699881763`*^9, {3.966991769839902*^9, 
   3.966991785623088*^9}, 3.966993125249909*^9, 3.966993393586197*^9, 
   3.9669934501181707`*^9, 3.9669938475770884`*^9, 3.982857789609434*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"e819506d-2490-421c-a2d3-23d385489c0a"]
}, Open  ]],

Cell[TextData[{
 "Here, ",
 StyleBox["CA", "Input"],
 " and ",
 StyleBox["C3FF", "Input"],
 " are  quadratic and cubic Casimir invariants respectively, ",
 StyleBox["DA", "Input"],
 " is the dimension of the adjoint representation, and ",
 StyleBox["TF", "Input"],
 " is the quadratic Dynkin index of the fundamental representation. "
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.953150598399734*^9, 3.953150614328239*^9}, {
  3.9531506491424637`*^9, 3.953150763103798*^9}, {3.953381336008728*^9, 
  3.953381362328638*^9}},ExpressionUUID->"198a944f-49c8-447d-a58f-\
c938e7f463de"],

Cell[TextData[{
 "Alternatively, we can explicitly evaluate the color factor in the QCD gauge \
group ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"SU", "(", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["c", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\text{SU}(n_c)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "483ee0b4-7e7b-4d1b-8bdd-559509b9d243"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["n", "TI"], 
        StyleBox["c", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "n_c", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bf297139-7c00-4d99-9b5d-9d0778c06c1b"],
 " is the number of colors:"
}], "Text",
 CellChangeTimes->{{3.953150788640934*^9, 
  3.953150846920608*^9}},ExpressionUUID->"5974f817-db50-4ebc-babd-\
f90e8e2b3b29"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"exprSUnc", "=", 
  RowBox[{"SUncReduce", "[", "expr", "]"}]}]], "Input",
 CellChangeTimes->{{3.9531508516684427`*^9, 3.953150862755938*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"bda27b4e-3e27-46bc-9762-d902542cac09"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox["1", "8"]}], "+", 
  FractionBox[
   RowBox[{"3", " ", 
    SuperscriptBox["nc", "2"]}], "16"], "-", 
  FractionBox[
   SuperscriptBox["nc", "4"], "16"]}]], "Output",
 CellChangeTimes->{3.9828577980551453`*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"72806a01-e678-4eec-aa35-366d7195d0ae"]
}, Open  ]],

Cell[TextData[{
 "Lastly, let\[CloseCurlyQuote]s ensure the answer ",
 StyleBox["exprCIFAR", "Input"],
 ", in terms of invariants, matches the above when ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"SU", "(", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["c", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\text{SU}(n_c)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d1784356-8866-45e3-8cea-d8ab21902060"],
 " values are plugged in:"
}], "Text",
 CellChangeTimes->{{3.953150879315299*^9, 3.953150977113587*^9}, {
   3.953159885477624*^9, 3.953159895547407*^9}, 
   3.9533813928220377`*^9},ExpressionUUID->"6c1cc072-d3ae-48ee-8b9a-\
7a79611655fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"SUncReduce", "[", "exprCIFAR", "]"}], "//", "Expand"}]], "Input",
 CellChangeTimes->{{3.953150978507812*^9, 3.953150986642125*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"dda86930-4585-4975-bb9e-28b352edaf7b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox["1", "8"]}], "+", 
  FractionBox[
   RowBox[{"3", " ", 
    SuperscriptBox["nc", "2"]}], "16"], "-", 
  FractionBox[
   SuperscriptBox["nc", "4"], "16"]}]], "Output",
 CellChangeTimes->{3.953150986907*^9, 3.953159806842251*^9, 
  3.9533812422703876`*^9, 3.961778779022324*^9, 3.9669931254502087`*^9, 
  3.9669933936615963`*^9, 3.966993450161235*^9, 3.966993847619906*^9, 
  3.982857801017358*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"1f9c78d1-8bc7-4932-9fbc-5678e6467132"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Step-by-step Reduction using Auxiliary Functions", "Subsection",
 CellChangeTimes->{{3.953151017015657*^9, 
  3.95315103270903*^9}},ExpressionUUID->"ae7f2d4c-2006-40f5-a0b5-\
4b75456e8821"],

Cell[TextData[{
 "Here, we do a step-by-step reduction using auxiliary functions that ",
 StyleBox["CIFARReduce", "Input"],
 " incorporates when fully reducing expressions."
}], "Text",
 CellChangeTimes->{{3.953151396447535*^9, 3.953151473572394*^9}, 
   3.953393290470777*^9},ExpressionUUID->"64aea5f0-feb1-43d2-988c-\
95bc24a79e14"],

Cell[TextData[{
 "First, we identify how the fundamental generators ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["t", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"]}], 
        StyleBox["a", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "t^{a}_{i j}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5db9c971-aa8d-42a0-912c-06fb471b63ba"],
 " are traced over, using ",
 StyleBox["ToTTProductForm", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.953151482250854*^9, 
  3.953151556345769*^9}},ExpressionUUID->"d1be5f05-d567-452d-9082-\
2b70dbfca86d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expr2", "=", 
  RowBox[{"ToTTProductForm", "[", "expr", "]"}]}]], "Input",
 CellChangeTimes->{{3.953151532178323*^9, 3.953151542029634*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"2737c281-c61a-4345-8858-c5fac6070196"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ff", "[", 
   RowBox[{"a2", ",", "a6", ",", "a4"}], "]"}], " ", 
  RowBox[{"ff", "[", 
   RowBox[{"a3", ",", "a4", ",", "a5"}], "]"}], " ", 
  RowBox[{"TT", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a3", ",", "a1", ",", "a2"}], "}"}], ",", "i4", ",", "i4"}], 
   "]"}], " ", 
  RowBox[{"TT", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a6", ",", "a1", ",", "a5"}], "}"}], ",", "j", ",", "j"}], 
   "]"}]}]], "Output",
 CellChangeTimes->{3.9531515422959633`*^9, 3.953159806857873*^9, 
  3.9533812422958307`*^9, 3.961778781225162*^9, 3.966993125486321*^9, 
  3.966993393792203*^9, 3.966993450282784*^9, 3.9669938476574783`*^9, 
  3.9828578067572317`*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"67a2cd89-82e1-49a4-9c23-2c36ffa94019"]
}, Open  ]],

Cell[TextData[{
 "Now, the fundamental traces are explicit in the form of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "1"], "\[Ellipsis]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["n", "TI"]]}]], "\[Congruent]", "Tr", 
         RowBox[{"[", 
           RowBox[{
             SuperscriptBox[
              StyleBox["t", "TI"], 
              SubscriptBox[
               StyleBox["a", "TI"], "1"]], "\[Ellipsis]", 
             SuperscriptBox[
              StyleBox["t", "TI"], 
              SubscriptBox[
               StyleBox["a", "TI"], 
               StyleBox["n", "TI"]]]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "T^{a_1 \\dots a_n}\\equiv \\text{Tr}[t^{a_1}\\dots t^{a_n}]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a9edf7ff-cccd-44a2-a4bf-6bb341b475a5"],
 "."
}], "Text",
 CellChangeTimes->{{3.953151565736598*^9, 3.953151620754684*^9}, {
   3.953151757118216*^9, 3.953151770553825*^9}, {3.953152213769773*^9, 
   3.9531522169339027`*^9}, {3.95315231761084*^9, 3.953152323475336*^9}, {
   3.953158131648869*^9, 3.9531582138257017`*^9}, 
   3.953159913783841*^9},ExpressionUUID->"ffe12897-f895-4895-9623-\
c24f635684a4"],

Cell[TextData[{
 "Normally, the next step would be to simplify adjoint contractions within a \
fundamental trace (e.g. a term like ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["T", "TI"], 
        RowBox[{
          StyleBox["a", "TI"], 
          StyleBox["b", "TI"], 
          StyleBox["c", "TI"], 
          StyleBox["a", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "T^{a b c a}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "228b4744-ed05-4644-960b-93b248b470b4"],
 ") and then double contractions between structure constants and fundamental \
traces (e.g. a term like ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "1"], 
            SubscriptBox[
             StyleBox["a", "TI"], "2"], 
            SubscriptBox[
             StyleBox["a", "TI"], "3"]}]], 
         SuperscriptBox[
          StyleBox["T", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "1"], 
            SubscriptBox[
             StyleBox["a", "TI"], "4"], 
            SubscriptBox[
             StyleBox["a", "TI"], "5"], 
            SubscriptBox[
             StyleBox["a", "TI"], "2"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "f^{a_1_a_2a_3}T^{a_1 a_4 a_5 a_2}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "251a24d8-046f-4837-b5be-6ae5ae6c4556"],
 "). This is not necessary for the term above. However, if necessary, the \
required functions are ",
 StyleBox["ContractTT", "Input"],
 " and ",
 StyleBox["ContractffTT", "Input"],
 " respectively; we display examples below."
}], "Text",
 CellChangeTimes->{{3.953151565736598*^9, 3.953151620754684*^9}, {
   3.953151757118216*^9, 3.953151770553825*^9}, {3.953152213769773*^9, 
   3.9531522169339027`*^9}, {3.95315231761084*^9, 3.953152323475336*^9}, {
   3.953158131648869*^9, 3.9531581647462473`*^9}, {3.953158263908424*^9, 
   3.953158282112108*^9}, {3.9531583373236427`*^9, 3.9531583775491133`*^9}, {
   3.953158408742944*^9, 3.9531584892773457`*^9}, {3.9531585668103247`*^9, 
   3.953158568379242*^9}, 
   3.9533933339932747`*^9},ExpressionUUID->"9c3f0bf4-b415-4b1d-8d1f-\
dc2307fd1804"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Simplify", " ", "contraction", " ", "within", " ", "a", " ", 
    "fundamental", " ", "trace"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"ContractTT", "[", 
   RowBox[{"TT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", "c", ",", "a"}], "}"}], ",", "i", ",", 
     "i"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.953158380575149*^9, 3.953158383025343*^9}, {
  3.953158491399171*^9, 3.953158511310834*^9}, {3.953159938854916*^9, 
  3.953159950039468*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"606b03b0-2cef-4baa-8db2-97ca6c88a0c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", "2"]}], " ", "CA", " ", "TF", " ", 
   RowBox[{"deltaA", "[", 
    RowBox[{"b", ",", "c"}], "]"}]}], "+", 
  RowBox[{"CF", " ", "TF", " ", 
   RowBox[{"deltaA", "[", 
    RowBox[{"b", ",", "c"}], "]"}]}], "+", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"ff", "[", 
    RowBox[{"c", ",", "a", ",", "a13"}], "]"}], " ", 
   RowBox[{"TT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", "a13"}], "}"}], ",", "i", ",", "i"}], 
    "]"}]}]}]], "Output",
 CellChangeTimes->{3.953158512086115*^9, 3.953159806880537*^9, 
  3.953381242324924*^9, 3.96177878364676*^9, 3.966993125525909*^9, 
  3.966993393831555*^9, 3.966993450315031*^9, 3.966993847690536*^9, 
  3.982857810065898*^9},
 CellLabel->"Out[12]=",ExpressionUUID->"b76dda28-1fcc-4cb3-82e5-7fdffb36c7a4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Simplify", " ", "double", " ", "contraction", " ", "between", " ", "a", 
    " ", "fundamental", " ", "trace", " ", "and", " ", "a", " ", "structure", 
    " ", "constant"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"ContractffTT", "[", 
   RowBox[{
    RowBox[{"ff", "[", 
     RowBox[{"a1", ",", "a2", ",", "a3"}], "]"}], 
    RowBox[{"TT", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a1", ",", "a4", ",", "a5", ",", "a2"}], "}"}], ",", "i", ",", 
      "i"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.953158516065756*^9, 3.953158541199831*^9}, {
  3.953159952953331*^9, 3.953159964703267*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"a60f99ad-1630-4930-a4fb-368b0cec5478"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"ff", "[", 
    RowBox[{"a1", ",", "a2", ",", "a3"}], "]"}], " ", 
   RowBox[{"ff", "[", 
    RowBox[{"a4", ",", "a2", ",", "a15"}], "]"}], " ", 
   RowBox[{"TT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a1", ",", "a15", ",", "a5"}], "}"}], ",", "i", ",", "i"}], 
    "]"}]}], "+", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"ff", "[", 
    RowBox[{"a1", ",", "a2", ",", "a3"}], "]"}], " ", 
   RowBox[{"ff", "[", 
    RowBox[{"a5", ",", "a2", ",", "a14"}], "]"}], " ", 
   RowBox[{"TT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a1", ",", "a4", ",", "a14"}], "}"}], ",", "i", ",", "i"}], 
    "]"}]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", "CA", " ", 
   RowBox[{"TT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a3", ",", "a4", ",", "a5"}], "}"}], ",", "i", ",", "i"}], 
    "]"}]}]}]], "Output",
 CellChangeTimes->{3.95315854280293*^9, 3.95315980689601*^9, 
  3.953381242356408*^9, 3.961778785009066*^9, 3.966993125560534*^9, 
