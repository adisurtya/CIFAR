 CellLabel->"Out[13]=",ExpressionUUID->"4cccc626-98c7-4b3f-97f8-51420b81ea78"]
}, Open  ]],

Cell[TextData[{
 "Now, there should be no adjoint contractions within a particular \
fundamental trace (i.e. all indices within a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["T", "TI"], 
        RowBox[{
          SubscriptBox[
           StyleBox["a", "TI"], "1"], "\[Ellipsis]", 
          SubscriptBox[
           StyleBox["a", "TI"], 
           StyleBox["n", "TI"]]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "T^{a_1 \\dots a_n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dc783262-c7cc-4050-96da-9c4468ba9479"],
 " are unique), and only single contractions between structure constants ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["f", "TI"], TraditionalForm], "errors" -> {}, "input" -> "f", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c459952f-46fb-4650-b2de-2cb1c83af195"],
 " and fundamental traces ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["T", "TI"], TraditionalForm], "errors" -> {}, "input" -> "T", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32cec0a5-afa2-4ed7-ae25-a34727c9e462"],
 "."
}], "Text",
 CellChangeTimes->{{3.953158553123856*^9, 3.9531585954652*^9}, {
  3.953159979467347*^9, 
  3.953160025674572*^9}},ExpressionUUID->"cc4208f0-fdb4-4719-be36-\
a7cdcbd79199"],

Cell[TextData[{
 "Returning to the original expression at hand, we now compute the traces of \
fundamental generators using ",
 StyleBox["TraceTT", "Input"],
 ", which should leave us with tensors only in the adjoint representation \
(including symmetric color tensors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["d", "TI"], 
        StyleBox["F", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "d_F", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "37ff1879-4428-441c-b822-41479fcd75f1"],
 "):"
}], "Text",
 CellChangeTimes->{{3.953151565736598*^9, 3.953151620754684*^9}, {
  3.953158597895557*^9, 3.953158631632147*^9}, {3.953158741968315*^9, 
  3.95315874456631*^9}, {3.953158800085964*^9, 
  3.9531588230889*^9}},ExpressionUUID->"30c428c2-2b33-4a07-88d8-115c01b207ba"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expr3", "=", 
  RowBox[{"expr2", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"TT", "[", 
      RowBox[{"a_", ",", "i_", ",", "i_"}], "]"}], ":>", 
     RowBox[{"TraceTT", "[", 
      RowBox[{"TT", "[", 
       RowBox[{"a", ",", "i", ",", "i"}], "]"}], "]"}]}], "}"}]}]}]], "Input",\

 CellChangeTimes->{{3.95315162228237*^9, 3.9531516911727*^9}, {
  3.95315230096154*^9, 3.953152301248637*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"967283b2-1566-4d12-843c-19042f93da41"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ff", "[", 
   RowBox[{"a2", ",", "a6", ",", "a4"}], "]"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"dF", "[", 
     RowBox[{"a1", ",", "a2", ",", "a3"}], "]"}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", "TF", " ", 
     RowBox[{"ff", "[", 
      RowBox[{"a3", ",", "a1", ",", "a2"}], "]"}]}]}], ")"}], " ", 
  RowBox[{"ff", "[", 
   RowBox[{"a3", ",", "a4", ",", "a5"}], "]"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"dF", "[", 
     RowBox[{"a1", ",", "a5", ",", "a6"}], "]"}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", "TF", " ", 
     RowBox[{"ff", "[", 
      RowBox[{"a6", ",", "a1", ",", "a5"}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{{3.953151659127927*^9, 3.9531516916116734`*^9}, 
   3.953152301645474*^9, 3.953159806915558*^9, 3.953381242384756*^9, 
   3.961778789360044*^9, 3.966993125600788*^9, 3.9669933939062157`*^9, 
