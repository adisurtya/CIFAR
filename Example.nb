Notebook[{

Cell[CellGroupData[{
Cell["CIFAR Example", "Title",
 CellChangeTimes->{{3.9531447023380404`*^9, 
  3.953144704900693*^9}},ExpressionUUID->"3377bf39-fe48-4d87-b1bc-\
39c96dd9bdc3"],

Cell[TextData[{
 "In this notebook, we present a brief example for the proper usage of ",
 StyleBox["CIFAR",
  FontSlant->"Italic"],
 " (Color Invariant Feynman Amplitude Reducer, pronounced \
\[OpenCurlyDoubleQuote]cipher\[CloseCurlyDoubleQuote]), a Mathematica package \
to express the color factors of Feynman diagrams in terms of Casimir \
invariants and dimensions of various representations of an arbitrary color \
algebra."
}], "Text",
 CellChangeTimes->{{3.953144707556939*^9, 3.9531447531162367`*^9}, {
  3.953150478670923*^9, 
  3.953150516023039*^9}},ExpressionUUID->"9ce1088c-ea27-4f67-b33f-\
78dd2e8a6407"],

Cell[CellGroupData[{

