Cell[BoxData[
 RowBox[{"expr5", "=", 
  RowBox[{"expr4", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FF", "[", "a_", "]"}], ":>", 
     RowBox[{"ContractFF", "[", 
      RowBox[{"FF", "[", "a", "]"}], "]"}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.953159011783124*^9, 3.953159040544692*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"f137e1d6-76e3-4348-8380-8c29f62ab120"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"C3FF", " ", "CA"}], "2"]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["TF", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["CA", "2"], " ", "DA"}], "-", 
     RowBox[{
      RowBox[{"ff", "[", 
       RowBox[{"a5", ",", "a2", ",", "a18"}], "]"}], " ", 
      RowBox[{"FF", "[", 
       RowBox[{"{", 
        RowBox[{"a2", ",", "a18", ",", "a5"}], "}"}], "]"}]}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{3.95315904284658*^9, 3.953159188948152*^9, 
  3.9531598069955*^9, 3.953381242484529*^9, 3.9617787926226892`*^9, 
  3.966993125720592*^9, 3.966993394000423*^9, 3.966993450498934*^9, 
  3.9669938478742933`*^9, 3.982857824541333*^9},
 CellLabel->"Out[16]=",ExpressionUUID->"b0ff8ccf-d23c-4aa1-a137-b55bab8702b0"]
}, Open  ]],

Cell[TextData[{
 "Now, there should be no adjoint contractions within a particular adjoint \
trace (i.e. all indices within a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["F", "TI"], 
        RowBox[{
          SubscriptBox[
           StyleBox["a", "TI"], "1"], "\[Ellipsis]", 
          SubscriptBox[
           StyleBox["a", "TI"], 
           StyleBox["n", "TI"]]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "F^{a_1 \\dots a_n}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f6caaa0a-a853-4b77-bf15-4faac6d58e50"],
 " are unique), and we can compute the adjoint trace in terms of symmetric \
color tensors and smaller traces:"
}], "Text",
 CellChangeTimes->{{3.9531590912785482`*^9, 3.9531591570938683`*^9}, {
  3.953160084010502*^9, 
  3.953160091627644*^9}},ExpressionUUID->"338fe576-6bca-4dc0-9198-\
3572dc21d5e7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expr6", "=", 
  RowBox[{"expr5", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FF", "[", "a_", "]"}], ":>", 
     RowBox[{"TraceFF", "[", 
      RowBox[{"FF", "[", "a", "]"}], "]"}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.9531591713999443`*^9, 3.9531591815038023`*^9}, {
  3.953159225416349*^9, 3.9531592325897923`*^9}, {3.953159331954144*^9, 
  3.9531593358079023`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"9ac08564-a41d-4297-aea1-6bc0ab17c757"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"C3FF", " ", "CA"}], "2"]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["TF", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["CA", "2"], " ", "DA"}], "-", 
