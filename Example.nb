 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"C3FF", " ", "CA"}], "2"]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", 
   SuperscriptBox["TF", "2"], " ", 
