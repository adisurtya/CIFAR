Cell[TextData[{
 "This introduces \[OpenCurlyDoubleQuote]loop\[CloseCurlyDoubleQuote] objects \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["F", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "1"], "\[Ellipsis]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["n", "TI"]]}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "1"], 
            SubscriptBox[
             StyleBox["i", "TI"], "1"], 
            SubscriptBox[
             StyleBox["i", "TI"], "2"]}]], 
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], "2"], 
            SubscriptBox[
             StyleBox["i", "TI"], "2"], 
            SubscriptBox[
             StyleBox["i", "TI"], "3"]}]], "\[Ellipsis]", 
         SuperscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["n", "TI"]], 
            SubscriptBox[
             StyleBox["i", "TI"], 
             StyleBox["n", "TI"]], 
            SubscriptBox[
             StyleBox["i", "TI"], "1"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "F^{a_1 \\dots a_n}=f^{a_1 i_1 i_2}f^{a_2 i_2 i_3} \\dots f^{a_n i_n \
i_1}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f3ed2ee5-0ed0-4944-9872-f98e9483d9ee"],
 ", which represent traces in the adjoint representation as a product of \
structure constants."
}], "Text",
 CellChangeTimes->{{3.9531588700741873`*^9, 3.953158885263074*^9}, {
  3.953158921700892*^9, 
  3.9531589440444098`*^9}},ExpressionUUID->"8e2bfc9c-f912-4a57-9b48-\
c77c54a20974"],

Cell[TextData[{
 "We simplify contractions within a particular ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["F", "TI"], TraditionalForm], "errors" -> {}, "input" -> "F", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e2e0e301-b17e-4ac5-9130-9e5223cf4c9c"],
 " using ",
 StyleBox["ContractFF", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9531589467352457`*^9, 
  3.953159006799362*^9}},ExpressionUUID->"27e383b0-3655-49cb-9cf5-\
51ff68472aaf"],

