 CellLabel->"Out[17]=",ExpressionUUID->"bfe10c53-5934-438a-bdc0-dcaaf09abe77"]
}, Open  ]],

Cell["Then, we repeat by finding (smaller) adjoint traces:", "Text",
 CellChangeTimes->{{3.953159353056456*^9, 
  3.953159370836578*^9}},ExpressionUUID->"b3daf180-f41c-42e3-a9bb-\
b32d22384ccd"],

