              MessageName[CIFAR`Private`FullyContractedQ, "highcount"], 
              MessageName[CIFAR`Private`FullyContractedQ, "nocolorobjects"]}]; 
           Null]; CIFAR`Private`result = Expand[CIFAR`Private`expr]; 
         Block[{CIFAR`TT, CIFAR`ff, CIFAR`FF, CIFAR`deltaF, CIFAR`deltaA, 
            CIFAR`dA, CIFAR`dF}, Get[CIFAR`$CIFARPath <> "lib/TT.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/ff.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/FFLoop.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/deltaF.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/deltaA.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/dA.m"]; 
           Get[CIFAR`$CIFARPath <> "lib/dF.m"]; 
           CIFAR`Private`result = CIFAR`ToTTProductForm[CIFAR`Private`result]; 
           CIFAR`Private`result = ReplaceAll[CIFAR`Private`result, {CIFAR`TT[
                  Pattern[CIFAR`Private`aa, 
                   Blank[]], 
                  Pattern[CIFAR`Private`ii, 
                   Blank[]], 
                  Pattern[CIFAR`Private`jj, 
                   Blank[]]]^2 :> CIFAR`ContractTT[
                  CIFAR`TT[
                  CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`jj]] 
                CIFAR`ContractTT[
                  CIFAR`TT[
                  CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`jj]]}]; 
           CIFAR`Private`result = ReplaceAll[CIFAR`Private`result, {CIFAR`TT[
                 Pattern[CIFAR`Private`aa, 
                  Blank[]], 
                 Pattern[CIFAR`Private`ii, 
                  Blank[]], 
                 Pattern[CIFAR`Private`jj, 
                  Blank[]]] :> CIFAR`ContractTT[
                 CIFAR`TT[
                 CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`jj]]}]; 
           CIFAR`Private`result = CIFAR`ContractffTT[CIFAR`Private`result]; 
           SetOptions[
            CIFAR`TraceTT, CIFAR`Tabulate -> OptionValue[CIFAR`Tabulate]]; 
           CIFAR`Private`result = ReplaceAll[CIFAR`Private`result, {CIFAR`TT[
                  Pattern[CIFAR`Private`aa, 
                   Blank[]], 
                  Pattern[CIFAR`Private`ii, 
                   Blank[]], 
                  Pattern[CIFAR`Private`ii, 
                   Blank[]]]^2 :> CIFAR`TraceTT[
                  CIFAR`TT[
                  CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`ii]] 
                CIFAR`TraceTT[
                  CIFAR`TT[
                  CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`ii]]}]; 
           CIFAR`Private`result = ReplaceAll[CIFAR`Private`result, {CIFAR`TT[
                 Pattern[CIFAR`Private`aa, 
                  Blank[]], 
                 Pattern[CIFAR`Private`ii, 
                  Blank[]], 
                 Pattern[CIFAR`Private`ii, 
                  Blank[]]] :> CIFAR`TraceTT[
                 CIFAR`TT[
                 CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`ii]]}]; 
           SetOptions[CIFAR`TraceTT, CIFAR`Tabulate -> True]; 
           CIFAR`Private`result = 
            CIFAR`AdjointReduce[
             CIFAR`Private`result, CIFAR`Private`fullyContractedQ, 
              CIFAR`Tabulate -> OptionValue[CIFAR`Tabulate]]; Null]; If[
           OptionValue[CIFAR`UseCache], 
           CIFAR`Private`UpdateCIFARReduceCache[
           CIFAR`Private`expr, CIFAR`Private`result]]; 
         Return[CIFAR`Private`result]; Null]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     CIFAR`CheckContractions -> True, CIFAR`UseCache -> True, CIFAR`Tabulate -> 
      True}, "Attributes" -> {}, "FullName" -> "CIFAR`CIFARReduce"|>, 
   False]]], "Output",
 CellChangeTimes->{3.953150297574552*^9, 3.953159806637179*^9, 
  3.953314018681036*^9, 3.953381242033777*^9, 3.961778756117556*^9, 
  3.966993020902339*^9, 3.966993125061947*^9, 3.966993393541473*^9, 
  3.966993449930456*^9, 3.966993847387314*^9, 3.982857766880641*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"569bfac7-2eed-4048-bb23-371667f26587"]
}, Open  ]]
