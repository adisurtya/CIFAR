  3.953144847732127*^9}},ExpressionUUID->"4295f11d-0ca6-40ed-9b40-\
3d321e2b7b93"],

Cell[CellGroupData[{

Cell["Loading the package", "Subsection",
 CellChangeTimes->{{3.953144854211102*^9, 
  3.953144862744781*^9}},ExpressionUUID->"d2831429-f26b-4598-8702-\
aa989a032914"],

Cell[TextData[{
 "To load the package, set the notebook directory to the one where ",
 StyleBox["CIFAR",
  FontSlant->"Italic"],
 " is installed."
}], "Text",
 CellChangeTimes->{{3.9531466033015842`*^9, 
  3.953146620622139*^9}},ExpressionUUID->"ce897342-a90d-4b58-8d07-\
1e5fa1c259da"],

