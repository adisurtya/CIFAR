 CellLabel->"Out[14]=",ExpressionUUID->"bc7015dd-7112-4671-9bb1-67eb32339454"]
}, Open  ]],

Cell[TextData[{
 "Now, all objects only carry adjoint indices. Next, we need to identify how \
the structure constants are traced over, using ",
 StyleBox["ToFFLoopForm", "Input"]
}], "Text",
 CellChangeTimes->{{3.953158656402432*^9, 3.953158671570937*^9}, {
  3.953158711354056*^9, 
  3.953158770300613*^9}},ExpressionUUID->"540db91e-3fb4-4932-894a-\
e49feee6b33b"],

