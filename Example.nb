                CIFAR`Private`GetAdjIndex[-1]])], True, 
           Module[{CIFAR`Private`result = Apply[CIFAR`dF, CIFAR`Private`a], 
              CIFAR`Private`perms = Permutations[
                Delete[CIFAR`Private`a, 1]], CIFAR`Private`currentPos, 
              CIFAR`Private`distinctPerms, CIFAR`Private`permsFactors}, 
             CIFAR`Private`perms = Insert[CIFAR`Private`perms, 
                Part[CIFAR`Private`a, 1], 
                Table[{CIFAR`Private`iter, 1}, {CIFAR`Private`iter, 
                  Length[CIFAR`Private`perms]}]]; 
             CIFAR`Private`permsFactors = Table[1, 
                Length[CIFAR`Private`perms]]; 
             Do[Do[CIFAR`Private`currentPos = Part[
                    Position[
                    Part[CIFAR`Private`perms, CIFAR`Private`iter2], 
                    Part[CIFAR`Private`a, CIFAR`Private`iter1]], 1, 1]; 
                 SubtractFrom[
                  CIFAR`Private`result, (
                    Part[CIFAR`Private`permsFactors, CIFAR`Private`iter2]/
                    Factorial[Length[CIFAR`Private`a] - 1]) 
                   CIFAR`Private`CommuteBackTTComTerms[
                    CIFAR`Private`GetTTFromInds[{
                    Part[CIFAR`Private`perms, CIFAR`Private`iter2]}, {{
                    CIFAR`Private`GetFundIndex[], 
                    CIFAR`Private`GetFundIndex[-1]}}], 
                    CIFAR`Private`currentPos, CIFAR`Private`iter1]]; 
                 Part[CIFAR`Private`perms, CIFAR`Private`iter2] = Insert[
                    Delete[
                    Part[CIFAR`Private`perms, CIFAR`Private`iter2], 
                    CIFAR`Private`currentPos], 
                    Part[CIFAR`Private`a, CIFAR`Private`iter1], 
                    CIFAR`Private`iter1], {CIFAR`Private`iter2, 
                  Length[CIFAR`Private`perms]}]; 
               CIFAR`Private`distinctPerms = 
                CIFAR`Private`PositionDistinct[CIFAR`Private`perms]; 
               CIFAR`Private`permsFactors = Map[Total, 
                  Table[
                   Part[CIFAR`Private`permsFactors, 
                    Part[CIFAR`Private`distinctPerms, CIFAR`Private`iter3]], {
                   CIFAR`Private`iter3, 
                    Length[CIFAR`Private`distinctPerms]}]]; 
               CIFAR`Private`perms = Part[CIFAR`Private`perms, 
                  Part[CIFAR`Private`distinctPerms, 
                   Span[1, All], 1]], {
               CIFAR`Private`iter1, 2, Length[CIFAR`Private`a] - 1}]; Return[
               ReplaceAll[
                Expand[CIFAR`Private`result], {CIFAR`TT[
                   Pattern[CIFAR`Private`aa, 
                    Blank[]], 
                   Pattern[CIFAR`Private`ii, 
                    Blank[]], 
                   Pattern[CIFAR`Private`ii, 
                    Blank[]]] :> CIFAR`TraceTT[
                   CIFAR`TT[
                   CIFAR`Private`aa, CIFAR`Private`ii, CIFAR`Private`ii]]}]]]; 
           Null]; Null], CIFAR`TraceTT[
         Pattern[CIFAR`Private`expr, 
          Blank[]]] :> CIFAR`Private`expr}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {CIFAR`Tabulate -> True}, "Attributes" -> {}, "FullName" -> 
    "CIFAR`TraceTT"|>, False]]], "Output",
