       RowBox[{"a5", ",", "a2", ",", "a18"}], "]"}]}]}], ")"}]}]}]], "Output",\

 CellChangeTimes->{
  3.9531591836679296`*^9, {3.9531592186989822`*^9, 3.953159233889892*^9}, 
